# Screenshot automation config
# Requires UI tests target in your Xcode project
# Run: fastlane snapshot

devices([
  "iPhone 16 Pro Max",   # 6.7" — required
  "iPhone 16 Pro",       # 6.3"
  "iPad Pro 13-inch (M4)" # 12.9" — required for iPad
])

languages(["en-US"])

output_directory("./fastlane/screenshots")
clear_previous_screenshots(true)

scheme("ClayLabUITests")

# Number of screenshots per device
number_of_retries(0)

# Stop on first error
stop_after_first_error(true)
